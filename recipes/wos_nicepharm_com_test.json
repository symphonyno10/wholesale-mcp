{
  "recipe_version": 2,
  "site_id": "wos_nicepharm_com_test",
  "site_name": "테스트",
  "site_url": "https://wos.nicepharm.com",
  "encoding": "utf-8",
  "connection": {
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "url": "/Common/Certify/Login.asp",
    "method": "POST",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "wos"
    },
    "cookie_parse": {
      "cookie_name": "wos",
      "format": "querystring",
      "fields": {
        "VEN_CD": "venCd",
        "MEM_KIND": "memKind",
        "STOCK_CD": "stockCd",
        "VEN_NM": "LoginVenNm"
      }
    }
  },
  "search": {
    "url": "/Service/Order/Order.asp",
    "method": "POST",
    "params": {
      "UserDef001": "02",
      "so": "0",
      "so2": "0",
      "tx_ven": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "currMkind": "{MEM_KIND}",
      "sv": "{VEN_CD}",
      "currStockCd": "{STOCK_CD}",
      "currSndStockCd": "",
      "df": "t",
      "sDate": "",
      "eDate": "",
      "tx_maker": "",
      "tx_physic": "{KEYWORD}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "#frmOrder .wrap_table .tbl_list tbody tr",
      "fields": {
        "product_code": {
          "selector": "input[name^='pc_']",
          "attribute": "value"
        },
        "product_name": "a.physic_nm::text",
        "manufacturer": "td:nth-child(2)::text",
        "pack_unit": "td:nth-child(4)::text",
        "unit_price": {
          "selector": "input[name^='price_']",
          "attribute": "value"
        },
        "stock_quantity": {
          "selector": "input[name^='stock_']",
          "attribute": "value"
        },
        "box_quantity": {
          "selector": "input[name^='boxqty_']",
          "attribute": "value"
        },
        "remark": {
          "selector": "input[name^='soldoutyn_']",
          "attribute": "value"
        }
      }
    },
    "pagination": {
      "type": "html_links",
      "paging_selector": ".paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 10
    }
  },
  "cart_add": {
    "type": "form",
    "url": "/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_"
  },
  "cart_view": {
    "url": "/Service/Order/Bag.asp",
    "method": "GET",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": "{MEM_KIND}",
      "currStockCd": "{STOCK_CD}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^='bagLine']",
      "fields": {
        "product_code": {
          "selector": "input[name^='pc_']",
          "attribute": "value"
        },
        "product_name": "a.bagPhysic_lnwide::text",
        "quantity": {
          "selector": "input[name^='bagQty_']",
          "attribute": "value"
        },
        "unit_price": {
          "selector": "input[name^='price_']",
          "attribute": "value"
        },
        "total_price": "td:nth-child(4)::text",
        "bag_num": {
          "selector": "input[name^='bag_num_']",
          "attribute": "value"
        },
        "stock_cd": {
          "selector": "input[name^='stockcd_']",
          "attribute": "value"
        }
      }
    }
  },
  "cart_delete": {
    "url": "/Service/Order/BagOrder.asp",
    "method": "GET",
    "requires_cart_view": true,
    "order_num_format": "{BAG_NUM}|{PRODUCT_CODE}|{STOCK_CD}|{QUANTITY}",
    "params": {
      "kind": "multiupdbag",
      "actflag": "DEL",
      "currVenCd": "{VEN_CD}",
      "currMkind": "{MEM_KIND}",
      "orderNum": "{ORDER_NUM}"
    },
    "success_indicator": {
      "type": "contains",
      "value": "삭제"
    }
  },
  "cart_clear": {
    "url": "/Service/Order/BagOrder.asp",
    "method": "GET",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": "{MEM_KIND}"
    }
  },
  "sales_ledger": {
    "url": "/Service/SalesLedger/SalesLedger.asp",
    "method": "GET",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "{DETAIL_MODE}",
      "tx_physic": "{PRODUCT_FILTER}"
    },
    "detail_values": {
      "detail": "0",
      "summary": "1"
    },
    "response_type": "html",
    "parsing": {
      "selector": ".tbl_list tbody tr[align='right']",
      "fields": {
        "transaction_date": "td:nth-child(2)::text",
        "product_name": "td.td_nm::text",
        "pack_unit": "td:nth-child(5)::text",
        "quantity": "td.td_num:nth-of-type(1)::text",
        "unit_price": "td.td_num:nth-of-type(2)::text",
        "sales_amount": "td.td_num:nth-of-type(3)::text"
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true
  }
}