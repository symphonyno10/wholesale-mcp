{
  "site_id": "ibjp_co_kr",
  "site_name": "백제약품",
  "site_url": "https://ibjp.co.kr",
  "encoding": "utf-8",
  "recipe_version": "1.0",
  "login": {
    "url": "https://www.ibjp.co.kr/jwt/login",
    "method": "POST",
    "content_type": "application/json",
    "payload": {
      "loginId": "{username}",
      "pwd": "{password}",
      "companyYn": "N"
    },
    "token": {
      "path": "accessToken",
      "header": "Authorization",
      "prefix": "Bearer ",
      "user_data_path": "userData"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "accessToken",
      "value": ""
    }
  },
  "search": {
    "url": "https://www.ibjp.co.kr/ord/itemSearch",
    "method": "GET",
    "params": {
      "keyword": "{keyword}",
      "makerNm": "",
      "history": "N",
      "excludingOutOfOtock": "N",
      "custCd": "{CUST_CD}",
      "custGbCd": "{CUST_GB_CD}",
      "ordMakerCd": "",
      "userGbCd": "{USER_GB_CD}",
      "ing": "N",
      "eff": "N",
      "ingno": "AAAAAAAAAAAAAA",
      "effno": "AAAAAAAAAAAA",
      "searchAll": "Y",
      "professionalYn": "N",
      "generalYn": "N",
      "paymentYn": "N",
      "nonPaymentYn": "N",
      "searchOption": "0"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "",
      "fields": {
        "product_code": "ITEM_CD",
        "product_name": "ITEM_NM",
        "manufacturer": "MAKER_NM",
        "pack_unit": "UNIT",
        "stock_quantity": "AVAIL_STOCK",
        "unit_price": "ORD_WP2_AMT",
        "edi_code": "BOHUM_CD",
        "insurance_type": "PAY_ITEM_NM"
      }
    }
  },
  "cart_add": {
    "type": "api",
    "url": "https://www.ibjp.co.kr/ord/addBasket",
    "method": "POST",
    "content_type": "application/json",
    "payload": {
      "basketGbCd": "01",
      "saveItemCd": "{product_code}",
      "saveItemGbCd": "01",
      "dlvBrchCd": "{DLV_BRCH_CD}",
      "saveItemQty": "{quantity}",
      "userId": "{USER_ID}",
      "custCd": "{CUST_CD}"
    },
    "success_indicator": {
      "type": "contains",
      "value": "정상적으로 처리되었습니다"
    }
  },
  "cart_view": {
    "url": "https://www.ibjp.co.kr/ord/basketList",
    "method": "GET",
    "params": {
      "userGbCd": "{USER_GB_CD}",
      "custCd": "{CUST_CD}",
      "basketGbCd": "01",
      "gDlvBrchFlag": ""
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "",
      "fields": {
        "product_code": "ITEM_CD",
        "product_name": "ITEM_NM",
        "quantity": "ITEM_QTY",
        "unit_price": "ORD_WP2_AMT",
        "manufacturer": "MAKER_NM",
        "pack_unit": "UNIT"
      }
    }
  },
  "cart_clear": {
    "url": "https://www.ibjp.co.kr/ord/deleteBasketAll",
    "method": "POST",
    "content_type": "application/json",
    "payload": {
      "custCd": "{CUST_CD}",
      "basketGbCd": "01"
    }
  },
  "sales_ledger": {
    "url": "https://www.ibjp.co.kr/ordLedger/listSearch",
    "method": "GET",
    "params": {
      "custCd": "{CUST_CD}",
      "custNm": "{CUST_NM}",
      "orderVal": "0",
      "startDt": "{start_date}",
      "endDt": "{end_date}",
      "searchAll": "Y",
      "salesYn": "N",
      "returnYn": "N",
      "paymentYn": "N",
      "compensationYn": "N",
      "sortType": "Web"
    },
    "date_format": "%Y%m%d",
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "date": "APRV_DT",
        "product_name": "ITEM_NM_UNIT",
        "sales_amount": "TOTAL_AMT",
        "balance": "BALANCE_A_AMT",
        "remark": "GUBUN_NM"
      }
    }
  },
  "connection": {
    "request_interval_ms": 500,
    "timeout_ms": 15000
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": false,
    "sales_ledger": true,
    "pagination": false
  }
}