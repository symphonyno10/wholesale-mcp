{
  "site_id": "wjwp_co_kr_auto",
  "site_name": "우정약품_auto",
  "site_url": "https://wjwp.co.kr",
  "encoding": "utf-8",
  "recipe_version": "1.0",
  "connection": {
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "method": "POST",
    "url": "/Common/Certify/Login.asp",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "cookie",
      "key": "wjwp"
    },
    "cookie_extract": {
      "cookie_name": "wjwp",
      "fields": {
        "VEN_CD": "venCd",
        "MEM_CD": "memCd",
        "MEM_ID": "memId",
        "VEN_NM": "venNm"
      }
    }
  },
  "search": {
    "method": "GET",
    "url": "/Service/Order/Order.asp",
    "params": {
      "tx_physic": "{KEYWORD}",
      "so": "0",
      "so2": "0",
      "df": "t"
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr.ln_physic",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": {
          "selector": "td:nth-child(3) a",
          "attribute": "text"
        },
        "manufacturer": {
          "selector": "td:nth-child(2)",
          "attribute": "text"
        },
        "edi_code": {
          "selector": "td:nth-child(1)",
          "attribute": "text"
        },
        "pack_unit": {
          "selector": "td:nth-child(4)",
          "attribute": "text"
        },
        "unit_price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        },
        "stock_quantity": {
          "selector": "input[name^=stock_]",
          "attribute": "value"
        }
      }
    },
    "pagination": {
      "type": "html_links",
      "paging_selector": "div.paging a",
      "page_url_param": "Page",
      "max_pages": 5
    }
  },
  "cart_add": {
    "type": "form",
    "url": "/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_"
  },
  "cart_view": {
    "method": "GET",
    "url": "/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^=bagLine]",
      "fields": {
        "product_name": {
          "selector": "a.bagPhysic_ln",
          "attribute": "text"
        },
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "quantity": {
          "selector": "input[name^=bagQty_]",
          "attribute": "value"
        },
        "unit_price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        },
        "total_price": {
          "selector": "input[name^=totalPrice]",
          "attribute": "value"
        }
      }
    }
  },
  "cart_delete": {
    "method": "POST",
    "url": "/Service/Order/ControlBag.asp",
    "payload": {
      "vc": "{VEN_CD}",
      "pc": "{PRODUCT_CODE}",
      "f": "true"
    },
    "content_type": "application/x-www-form-urlencoded"
  },
  "cart_clear": {
    "method": "GET",
    "url": "/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}"
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "/Service/SalesLedger/SalesLedger.asp",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "transgu": "{DETAIL_MODE}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "table.tbl_list:nth-of-type(2) tbody tr[align=right]",
      "fields": {
        "transaction_date": {
          "selector": "td:nth-child(2)",
          "attribute": "text"
        },
        "manufacturer": {
          "selector": "td.td_nm:nth-of-type(1)",
          "attribute": "text"
        },
        "product_name": {
          "selector": "td.td_nm:nth-of-type(2)",
          "attribute": "text"
        },
        "pack_unit": {
          "selector": "td:nth-child(5)",
          "attribute": "text"
        },
        "quantity": {
          "selector": "td.td_num:nth-of-type(1)",
          "attribute": "text"
        },
        "unit_price": {
          "selector": "td.td_num:nth-of-type(2)",
          "attribute": "text"
        },
        "sales_amount": {
          "selector": "td.td_num:nth-of-type(3)",
          "attribute": "text"
        }
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true,
    "order_submit": false
  }
}