{
  "site_id": "ibjp_co_kr_auto",
  "site_name": "백제약품_auto",
  "site_url": "https://ibjp.co.kr",
  "encoding": "utf-8",
  "recipe_version": 1,
  "connection": {
    "base_url": "https://www.ibjp.co.kr",
    "request_interval_ms": 300
  },
  "login": {
    "method": "POST",
    "url": "https://www.ibjp.co.kr/jwt/login",
    "payload": {
      "loginId": "{USERNAME}",
      "pwd": "{PASSWORD}",
      "companyYn": "N"
    },
    "content_type": "application/json",
    "success_indicator": {
      "type": "json_field",
      "path": "accessToken"
    },
    "token": {
      "path": "accessToken",
      "header": "Authorization",
      "prefix": "Bearer ",
      "user_data_path": "userData"
    }
  },
  "search": {
    "method": "GET",
    "url": "https://www.ibjp.co.kr/ord/itemSearch",
    "params": {
      "keyword": "{KEYWORD}",
      "makerNm": "",
      "history": "N",
      "excludingOutOfOtock": "N",
      "custCd": "{CUST_CD}",
      "custGbCd": "01",
      "ordMakerCd": "",
      "userGbCd": "30",
      "ing": "N",
      "eff": "N",
      "ingno": "AAAAAAAAAAAAAA",
      "effno": "AAAAAAAAAAAA",
      "searchAll": "Y",
      "professionalYn": "N",
      "generalYn": "N",
      "paymentYn": "N",
      "nonPaymentYn": "N",
      "searchOption": "0"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "",
      "fields": {
        "product_code": "ITEM_CD",
        "product_name": "ITEM_NM",
        "unit_price": "ORD_WP2_AMT",
        "stock_quantity": "AVAIL_STOCK",
        "manufacturer": "MAKER_NM",
        "unit": "UNIT",
        "insurance_code": "BOHUM_CD",
        "product_name_unit": "ITEM_NM_UNIT"
      }
    }
  },
  "cart_add": {
    "method": "POST",
    "url": "https://www.ibjp.co.kr/ord/addBasket",
    "payload": {
      "basketGbCd": "01",
      "saveItemCd": "{PRODUCT_CODE}",
      "saveItemGbCd": "01",
      "dlvBrchCd": "{DLV_BRCH_CD}",
      "saveItemQty": "{QUANTITY}",
      "userId": "{USER_ID}",
      "custCd": "{CUST_CD}"
    },
    "content_type": "application/json",
    "success_indicator": {
      "type": "contains",
      "text": "정상적으로 처리되었습니다"
    }
  },
  "cart_view": {
    "method": "GET",
    "url": "https://www.ibjp.co.kr/ord/basketList",
    "params": {
      "userGbCd": "30",
      "custCd": "{CUST_CD}",
      "basketGbCd": "01",
      "gDlvBrchFlag": ""
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "",
      "fields": {
        "product_code": "ITEM_CD",
        "product_name": "ITEM_NM",
        "unit_price": "ORD_WP2_AMT",
        "quantity": "ITEM_QTY",
        "manufacturer": "MAKER_NM",
        "unit": "UNIT"
      }
    }
  },
  "cart_delete": {
    "method": "DELETE",
    "url": "https://www.ibjp.co.kr/ord/deleteComOrdBasket",
    "params": {
      "userId": "{USER_ID}",
      "custCd": "{CUST_CD}",
      "itemQty": "",
      "ordWp2Amt": "",
      "basketGbCd": "01",
      "saveItemGbCd": "01",
      "saveItemCd": "{PRODUCT_CODE}",
      "dlvBrchCd": "{DLV_BRCH_CD}"
    },
    "success_indicator": {
      "type": "contains",
      "text": "정상적으로 처리되었습니다"
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "https://www.ibjp.co.kr/ordLedger/listSearch",
    "date_format": "%Y%m%d",
    "params": {
      "custCd": "{CUST_CD}",
      "custNm": "{CUST_NM}",
      "orderVal": "0",
      "startDt": "{START_DATE}",
      "endDt": "{END_DATE}",
      "searchAll": "Y",
      "salesYn": "N",
      "returnYn": "N",
      "paymentYn": "N",
      "compensationYn": "N",
      "sortType": "Web"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "date": "APRV_DT",
        "product_name": "ITEM_NM_UNIT",
        "total_amount": "TOTAL_AMT",
        "payment_amount": "PAY_AMT",
        "balance": "BALANCE_A_AMT",
        "approval_no": "APRV_NO",
        "order_type": "ORD_TYPE_NM",
        "category": "GUBUN_NM",
        "item_count": "ITEM_CNT_TXT",
        "sn": "SN"
      }
    },
    "sales_ledger_detail": {
      "method": "GET",
      "url": "https://www.ibjp.co.kr/ordLedger/detailSearch",
      "params": {
        "sn": "{SN}"
      },
      "response_type": "json",
      "json_mapping": {
        "items_path": "custList",
        "fields": {
          "product_name": "ITEM_NM_UNIT",
          "manufacturer": "MAKER_NM",
          "insurance_code": "BOHUM_CD",
          "unit_price": "ORD_WP2_AMT",
          "quantity": "ITEM_QTY",
          "total_amount": "TOTAL_AMT",
          "expiry_date": "EXP_DT",
          "product_code": "PROD_NO"
        }
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": false,
    "sales_ledger": true,
    "sales_ledger_detail": true,
    "order_submit": false
  }
}