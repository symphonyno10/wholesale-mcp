{
  "site_id": "wos_kps2013_co_kr",
  "site_name": "한국의약품물류",
  "site_url": "http://wos.kps2013.co.kr",
  "encoding": "utf-8",
  "recipe_version": 4,
  "connection": {
    "request_interval_ms": 500,
    "ssl_verify": false
  },
  "login": {
    "method": "POST",
    "url": "/Common/Certify/Login.asp",
    "content_type": "application/x-www-form-urlencoded",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "wos"
    },
    "cookie_parse": {
      "cookie_name": "wos",
      "format": "querystring",
      "fields": {
        "VEN_CD": "venCd",
        "VEN_NM": "venNm"
      }
    }
  },
  "search": {
    "method": "GET",
    "url": "/Service/Order/Order.asp",
    "params": {
      "so": "0",
      "so2": "0",
      "tx_physic": "{KEYWORD}",
      "tx_maker": "",
      "tx_ven": "{VEN_CD}",
      "tx_StockLoc": "'00001'",
      "currVenNm": "{VEN_NM}",
      "currMkind": "",
      "df": "t"
    },
    "response_type": "html",
    "parsing": {
      "selector": "#frmOrder table.tbl_list tbody tr",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value",
          "source": "form_hidden"
        },
        "product_name": {
          "selector": "td:nth-child(3)",
          "attribute": "text"
        },
        "manufacturer": {
          "selector": "td:nth-child(2)",
          "attribute": "text"
        },
        "pack_unit": {
          "selector": "td:nth-child(4)",
          "attribute": "text"
        },
        "unit_price": {
          "selector": "input[name^=price_]",
          "attribute": "value",
          "source": "form_hidden"
        },
        "stock_quantity": {
          "selector": "td:nth-child(7)",
          "attribute": "text"
        }
      }
    },
    "pagination": {
      "type": "html_links",
      "paging_selector": "#paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 5
    }
  },
  "cart_add": {
    "type": "form",
    "url": "/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_"
  },
  "cart_view": {
    "method": "GET",
    "url": "/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": "",
      "currLoc": "'00001'",
      "currRealVenCd": ""
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^=bagLine]",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": "td:nth-child(2)",
        "quantity": {
          "selector": "input[name^=bagQty_]",
          "attribute": "value"
        },
        "unit_price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        }
      }
    }
  },
  "cart_clear": {
    "method": "GET",
    "url": "/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": "",
      "currRealVenCd": ""
    },
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "/Service/SalesLedger/SalesLedger.asp",
    "date_format": "%Y-%m-%d",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "{DETAIL_MODE}",
      "tp": ""
    },
    "detail_values": {
      "detail": "0",
      "summary": "1"
    },
    "response_type": "html",
    "parsing": {
      "selector": "table tbody tr",
      "fields": {
        "transaction_date": "td:nth-child(2)",
        "manufacturer": "td:nth-child(3)",
        "product_name": "td:nth-child(4)",
        "pack_unit": "td:nth-child(5)",
        "quantity": "td:nth-child(6)",
        "unit_price": "td:nth-child(7)",
        "sales_amount": "td:nth-child(8)"
      }
    }
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": true
  }
}
