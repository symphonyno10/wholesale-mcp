{
  "site_id": "wjwp_co_kr",
  "site_name": "우정약품",
  "site_url": "https://wjwp.co.kr",
  "encoding": "utf-8",
  "recipe_version": "1.0",
  "login": {
    "url": "https://wjwp.co.kr/Common/Certify/Login.asp",
    "method": "POST",
    "payload": {
      "tx_id": "{username}",
      "tx_pw": "{password}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "wjwp"
    }
  },
  "search": {
    "url": "https://wjwp.co.kr/Service/Order/Order.asp",
    "method": "GET",
    "params": {
      "tx_physic": "{keyword}",
      "so": "0",
      "so2": "0"
    },
    "response_type": "html",
    "parsing": {
      "row_selector": "#frmOrder .wrap_table table.tbl_list tbody tr",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": "td:nth-child(3)",
        "manufacturer": "td:nth-child(2)",
        "specification": "td:nth-child(4)",
        "category": "td:nth-child(5)",
        "price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        },
        "stock": "td:nth-child(7)"
      }
    },
    "pagination": {
      "type": "html_links",
      "paging_selector": "div.paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 5
    }
  },
  "cart_add": {
    "type": "form",
    "url": "https://wjwp.co.kr/Service/Order/BagOrder.asp",
    "method": "POST",
    "form_selector": "#frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_",
    "additional_fields": {
      "kind": "saveAll",
      "currVenCd": "{VEN_CD}",
      "userId": "{username}"
    }
  },
  "cart_view": {
    "url": "https://wjwp.co.kr/Service/Order/Bag.asp",
    "method": "GET",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": ""
    },
    "response_type": "html",
    "parsing": {
      "row_selector": "table.tbl_list tbody tr",
      "fields": {
        "product_name": "td:nth-child(2)",
        "specification": "td:nth-child(3)",
        "quantity": "td:nth-child(4)",
        "price": "td:nth-child(5)"
      }
    }
  },
  "cart_clear": {
    "url": "https://wjwp.co.kr/Service/Order/BagOrder.asp",
    "method": "GET",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": ""
    }
  },
  "sales_ledger": {
    "url": "https://wjwp.co.kr/Service/SalesLedger/SalesLedger.asp",
    "method": "GET",
    "params": {
      "sDate": "{start_date}",
      "eDate": "{end_date}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "0"
    },
    "date_format": "%Y-%m-%d",
    "response_type": "html",
    "parsing": {
      "row_selector": "table.tbl_list tbody tr",
      "fields": {
        "date": "td:nth-child(2)",
        "product_name": "td:nth-child(3)",
        "specification": "td:nth-child(4)",
        "quantity": "td:nth-child(5)",
        "unit_price": "td:nth-child(6)",
        "sales_amount": "td:nth-child(7)",
        "balance": "td:nth-child(10)"
      }
    }
  },
  "connection": {
    "request_interval_ms": 500,
    "timeout_ms": 15000
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": true
  }
}