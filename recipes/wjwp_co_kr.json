{
  "recipe_version": 4,
  "site_url": "https://wjwp.co.kr",
  "site_id": "wjwp_co_kr",
  "site_name": "우정약품",
  "encoding": "utf-8",
  "analyzed_by": "mcp-browser-analysis",
  "analyzed_at": "2026-03-21T14:00:00.000000+00:00",
  "connection": {
    "pre_login_get": true,
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "method": "POST",
    "url": "https://wjwp.co.kr/Common/Certify/Login.asp",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "cookie",
      "key": "wjwp"
    }
  },
  "search": {
    "method": "GET",
    "url": "https://wjwp.co.kr/Service/Order/Order.asp",
    "params": {
      "so": "0",
      "so2": "0",
      "tx_physic": "{KEYWORD}",
      "tx_maker": ""
    },
    "response_type": "html",
    "content_type": "application/x-www-form-urlencoded",
    "pagination": {
      "type": "html_links",
      "paging_selector": "div.paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 5
    },
    "parsing": {
      "selector": "tr.ln_physic",
      "fields": {
        "edi_code": {
          "selector": "td:nth-child(1)",
          "attribute": "text"
        },
        "manufacturer": {
          "selector": "td:nth-child(2)",
          "attribute": "text"
        },
        "product_name": {
          "selector": "td:nth-child(3) a",
          "attribute": "text"
        },
        "pack_unit": {
          "selector": "td:nth-child(4)",
          "attribute": "text"
        },
        "unit_price": {
          "selector": "td:nth-child(6)",
          "attribute": "text"
        },
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "stock_quantity": {
          "selector": "input[name^=stock_]",
          "attribute": "value"
        },
        "price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        }
      }
    }
  },
  "cart_add": {
    "type": "form",
    "method": "POST",
    "url": "https://wjwp.co.kr/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_",
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "cart_view": {
    "method": "GET",
    "url": "https://wjwp.co.kr/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": ""
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^=bagLine]",
      "fields": {
        "product_name": {"selector": "td.td_nm a", "attribute": "text"},
        "product_code": {"selector": "input[name^=pc_]", "attribute": "value"},
        "quantity": {"selector": "input[name^=bagQty_]", "attribute": "value"},
        "unit_price": {"selector": "input[name^=price_]", "attribute": "value"},
        "total_price": {"selector": "td.td_num", "attribute": "text"}
      }
    }
  },
  "cart_delete": {
    "method": "POST",
    "url": "https://wjwp.co.kr/Service/Order/ControlBag.asp",
    "payload": {
      "vc": "{VEN_CD}",
      "pc": "{PRODUCT_CODE}",
      "f": "true"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "status_code",
      "value": 200
    },
    "notes": "삭제가 아닌 주문 제외 처리. f=true로 제외, f=false로 복원."
  },
  "cart_clear": {
    "method": "GET",
    "url": "https://wjwp.co.kr/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": "",
      "currRealVenCd": ""
    },
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "https://wjwp.co.kr/Service/SalesLedger/SalesLedger.asp",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "{DETAIL_MODE}",
      "tx_physic": "{PRODUCT_FILTER}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "table.tbl_list tbody tr[align='right']",
      "fields": {
        "transaction_date": {"selector": "td:nth-child(2)", "attribute": "text"},
        "product_name": {"selector": "td.td_nm", "attribute": "text"},
        "pack_unit": {"selector": "td:nth-child(5)", "attribute": "text"},
        "quantity": {"selector": "td:nth-child(6)", "attribute": "text"},
        "unit_price": {"selector": "td:nth-child(7)", "attribute": "text"},
        "sales_amount": {"selector": "td:nth-child(8)", "attribute": "text"},
        "balance": {"selector": "td.last", "attribute": "text"}
      }
    }
  }
}
