{
  "site_id": "wjwp_co_kr",
  "site_name": "우정약품",
  "site_url": "https://wjwp.co.kr",
  "encoding": "utf-8",
  "recipe_version": 4,
  "connection": {
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "method": "POST",
    "url": "/Common/Certify/Login.asp",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "wjwp"
    }
  },
  "search": {
    "method": "GET",
    "url": "/Service/Order/Order.asp",
    "params": {
      "so": "0",
      "so2": "0",
      "tx_physic": "{KEYWORD}",
      "tx_maker": "",
      "tx_ven": "{VEN_CD}",
      "currVenNm": "{VEN_NM}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "#frmOrder table.tbl_list tbody tr",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": "td:nth-child(3)",
        "manufacturer": "td:nth-child(2)",
        "pack_unit": "td:nth-child(4)",
        "price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        },
        "stock_quantity": "td:nth-child(7)",
        "remark": "td:nth-child(5)"
      }
    },
    "pagination": {
      "type": "html_links",
      "paging_selector": "div.paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 5
    }
  },
  "cart_add": {
    "type": "form",
    "url": "/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_"
  },
  "cart_view": {
    "method": "GET",
    "url": "/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": "",
      "currRealVenCd": ""
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^=bagLine]",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": "td:nth-child(2)",
        "quantity": {
          "selector": "input[name^=bagQty_]",
          "attribute": "value"
        },
        "total_price": "td:nth-child(4)"
      }
    }
  },
  "cart_clear": {
    "method": "GET",
    "url": "/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": "",
      "currRealVenCd": ""
    },
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "/Service/SalesLedger/SalesLedger.asp",
    "date_format": "%Y-%m-%d",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "0"
    },
    "response_type": "html",
    "parsing": {
      "selector": "table:last-of-type tbody tr",
      "fields": {
        "transaction_date": "td:nth-child(2)",
        "product_name": "td.td_nm",
        "quantity": "td:nth-child(5)",
        "unit_price": "td:nth-child(6)",
        "sales_amount": "td:nth-child(8)",
        "balance": "td:nth-child(12)"
      }
    }
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": true
  }
}