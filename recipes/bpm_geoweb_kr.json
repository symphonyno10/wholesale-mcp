{
  "site_id": "bpm_geoweb_kr",
  "site_name": "지오영",
  "site_url": "https://bpm.geoweb.kr",
  "encoding": "utf-8",
  "recipe_version": "1.0",
  "login": {
    "url": "https://bpm.geoweb.kr/Member/Login",
    "method": "POST",
    "payload": {
      "LoginID": "{username}",
      "Password": "{password}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "GEORELAUTH"
    }
  },
  "search": {
    "url": "https://bpm.geoweb.kr/Home/PartialSearchProduct",
    "method": "POST",
    "params": {
      "srchText": "{keyword}",
      "srchCate": "",
      "prdtType": "",
      "prdOrder": "3",
      "srchCompany": "",
      "startdate": "",
      "enddate": ""
    },
    "response_type": "html",
    "parsing": {
      "row_selector": "tr.tr-product-list",
      "fields": {
        "product_code": "div.div-product-detail ul li:first-child",
        "product_name": "td.proName",
        "manufacturer": "td.phaCompany span",
        "specification": "td.standard",
        "stock": "td.stock span"
      }
    },
    "product_detail": {
      "method": "POST",
      "url": "https://bpm.geoweb.kr/Home/PartialProductInfo/{PRODUCT_CODE}",
      "payload": {"num": "{STOCK_QUANTITY}"},
      "response_type": "html",
      "unit_price_selector": "#div_product_price ul li:nth-child(3)",
      "notes": "검색 목록에 가격 없음. 상품 클릭 시 제품정보 패널에서 주문단가 확인."
    }
  },
  "cart_add": {
    "type": "api",
    "url": "https://bpm.geoweb.kr/Home/DataCart/add",
    "method": "POST",
    "payload": {
      "productCode": "{product_code}",
      "moveCode": "",
      "orderQty": "{quantity}"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "result",
      "value": "1"
    }
  },
  "cart_view": {
    "url": "https://bpm.geoweb.kr/Home/PartialProductCart",
    "method": "POST",
    "response_type": "html",
    "parsing": {
      "row_selector": "table tbody tr",
      "fields": {
        "product_name": "td.phaCompany",
        "quantity": "td.quantity",
        "price": "td.unitPrice",
        "total": "td.amountMoney"
      }
    }
  },
  "cart_delete": {
    "url": "https://bpm.geoweb.kr/Home/DataCart/del",
    "method": "POST",
    "payload": {
      "productCode": "{product_code}",
      "moveCode": "",
      "orderQty": "0"
    }
  },
  "cart_clear": {
    "url": "https://bpm.geoweb.kr/Home/DataCart/delAll",
    "method": "POST"
  },
  "sales_ledger": {
    "url": "https://bpm.geoweb.kr/MyPage/SalesLedger",
    "method": "GET",
    "params": {
      "dtpFrom": "{start_date}",
      "dtpTo": "{end_date}",
      "printFlag": "2",
      "srchFlag": ""
    },
    "date_format": "%Y-%m-%d",
    "response_type": "html",
    "parsing": {
      "row_selector": "table tbody tr",
      "fields": {
        "date": "td.date",
        "product_name": "td.proName",
        "sales_amount": "td.salAmountMoney",
        "deposit_amount": "td.dipAmountMoney",
        "balance": "td.balance"
      }
    }
  },
  "connection": {
    "request_interval_ms": 500,
    "timeout_ms": 15000
  }
}