{
  "site_id": "bpm_geoweb_kr",
  "site_name": "지오웹BPM",
  "site_url": "https://bpm.geoweb.kr",
  "encoding": "utf-8",
  "recipe_version": "2.0",
  "connection": {
    "request_interval_ms": 500
  },
  "login": {
    "url": "/Member/Login",
    "method": "POST",
    "payload": {
      "LoginID": "{USERNAME}",
      "Password": "{PASSWORD}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "GEORELAUTH"
    }
  },
  "search": {
    "url": "/Home/PartialSearchProduct",
    "method": "POST",
    "params": {
      "srchCate": "",
      "prdtType": "",
      "prdOrder": "3",
      "srchText": "{KEYWORD}",
      "srchCompany": "",
      "startdate": "",
      "enddate": ""
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr.tr-product-list",
      "fields": {
        "product_code": {
          "selector": ".div-product-detail li:first-child",
          "attribute": "text"
        },
        "product_name": "td.proName",
        "manufacturer": "td.phaCompany span",
        "pack_unit": "td.standard",
        "stock_quantity": "td.stock span",
        "edi_code": "td.code"
      }
    }
  },
  "product_detail": {
    "url": "/Home/PartialProductInfo/{PRODUCT_CODE}",
    "method": "POST",
    "params": {
      "num": "0"
    },
    "response_type": "html",
    "note": "검색 결과에 단가 없음. 이 API로 개별 상품 단가 조회 가능. 응답 HTML 내 '주문단가' 행의 td에서 가격 추출."
  },
  "cart_add": {
    "url": "/Home/DataCart/add",
    "method": "POST",
    "payload": {
      "productCode": "{PRODUCT_CODE}",
      "moveCode": "",
      "orderQty": "{QUANTITY}"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "result",
      "value": "1"
    }
  },
  "cart_view": {
    "url": "/Home/PartialProductCart",
    "method": "POST",
    "response_type": "html",
    "parsing": {
      "selector": "tr.tr_cart_list",
      "fields": {
        "product_code": {
          "selector": ".div_cart_detail li:first-child",
          "attribute": "text"
        },
        "product_name": "td.phaCompany",
        "quantity": {
          "selector": ".div_cart_detail li:nth-child(4)",
          "attribute": "text"
        },
        "unit_price": "td.unitPrice",
        "total_price": "td.amountMoney"
      }
    }
  },
  "cart_delete": {
    "url": "/Home/DataCart/del",
    "method": "POST",
    "payload": {
      "productCode": "{PRODUCT_CODE}",
      "moveCode": "",
      "orderQty": "0"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "result",
      "value": "1"
    }
  },
  "cart_clear": {
    "url": "/Home/DataCart/alldel",
    "method": "POST",
    "payload": {
      "productCode": "",
      "moveCode": "",
      "orderQty": "0"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "result",
      "value": "1"
    }
  },
  "sales_ledger": {
    "url": "/MyPage/SalesLedger",
    "method": "GET",
    "params": {
      "dtpFrom": "{START_DATE}",
      "dtpTo": "{END_DATE}",
      "printFlag": "{DETAIL_MODE}",
      "srchFlag": ""
    },
    "detail_values": {
      "detail": "2",
      "summary": "1"
    },
    "response_type": "html",
    "parsing": {
      "selector": "tbody tr",
      "fields": {
        "transaction_date": "td.date",
        "product_name": "td.proName",
        "quantity": "td.quantity",
        "unit_price": "td.salUnitPrice",
        "sales_amount": "td.salAmountMoney",
        "payment": "td.dipAmountMoney",
        "balance": "td.balance"
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true,
    "product_detail": true
  }
}