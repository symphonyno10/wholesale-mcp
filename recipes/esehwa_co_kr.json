{
  "site_id": "esehwa_co_kr",
  "site_name": "세화약품",
  "site_url": "https://esehwa.co.kr",
  "encoding": "utf-8",
  "recipe_version": "1.0",
  "login": {
    "url": "https://esehwa.co.kr/common/ajax/user.asp",
    "method": "POST",
    "payload": {
      "id": "{username}",
      "pw": "{password}",
      "mode": "login",
      "chked": "false"
    },
    "success_indicator": {
      "type": "contains",
      "value": "0000"
    }
  },
  "search": {
    "url": "https://esehwa.co.kr/common/ajax/physic.asp",
    "method": "GET",
    "params": {
      "mode": "list",
      "f": "1",
      "unityGu": "",
      "physicNm": "{keyword}",
      "venNm": "",
      "insuCd": "",
      "page": "1",
      "often": "0",
      "flag": "",
      "physicCd": "",
      "gu": "",
      "rank": "",
      "mask": "",
      "consCd": "",
      "consCdSeq": "",
      "effect": "0"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "manufacturer": "makerNm",
        "pack_unit": "std",
        "stock_quantity": "stock",
        "unit_price": "unitCost",
        "insurance_type": "phyGroupNm",
        "remark": "soldoutMsg"
      }
    },
    "pagination": {
      "type": "param",
      "page_param": "page",
      "start_page": 1,
      "total_pages_path": "totalPage",
      "max_pages": 10
    }
  },
  "cart_add": {
    "type": "api",
    "url": "https://esehwa.co.kr/common/ajax/bag.asp",
    "method": "POST",
    "payload": {
      "physicCds": "{product_code}",
      "qtys": "{quantity}",
      "unitCosts": "0",
      "mode": "add",
      "ug": "",
      "orderFlag": "1"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "cart_view": {
    "url": "https://esehwa.co.kr/common/ajax/bag.asp",
    "method": "GET",
    "params": {
      "mode": "list",
      "ug": "",
      "orderFlag": "1"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "quantity": "qty",
        "unit_price": "price",
        "manufacturer": "maker",
        "pack_unit": "std"
      }
    }
  },
  "cart_clear": {
    "url": "https://esehwa.co.kr/common/ajax/bag.asp",
    "method": "POST",
    "payload": {
      "mode": "deleteAll",
      "ug": "",
      "orderFlag": "1"
    }
  },
  "sales_ledger": {
    "url": "https://esehwa.co.kr/contents/order/saleledger.asp",
    "method": "GET",
    "params": {
      "tx_dateA": "{start_date}",
      "tx_dateZ": "{end_date}",
      "srchFlag": "1",
      "sel_kind": "1",
      "sel_srch_opt": "",
      "ug": "",
      "tx_physic_nm": ""
    },
    "date_format": "%Y-%m-%d",
    "response_type": "html",
    "parsing": {
      "row_selector": "table.tbl_list tbody tr",
      "fields": {
        "date": "td:nth-child(1)",
        "product_name": "td:nth-child(3)",
        "specification": "td:nth-child(4)",
        "quantity": "td:nth-child(5)",
        "unit_price": "td:nth-child(6)",
        "sales_amount": "td:nth-child(7)",
        "balance": "td:nth-child(9)"
      }
    }
  },
  "connection": {
    "request_interval_ms": 500,
    "timeout_ms": 15000
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": true
  }
}