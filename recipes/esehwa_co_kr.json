{
  "site_id": "esehwa_co_kr_auto",
  "site_name": "세화약품",
  "site_url": "https://www.esehwa.co.kr",
  "encoding": "utf-8",
  "recipe_version": "2.0",
  "connection": {
    "base_url": "https://www.esehwa.co.kr",
    "request_interval_ms": 300
  },
  "login": {
    "url": "/common/ajax/user.asp",
    "method": "POST",
    "content_type": "application/x-www-form-urlencoded",
    "payload": {
      "chked": "false",
      "id": "{USERNAME}",
      "pw": "{PASSWORD}",
      "mode": "login"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "ESEHWAui"
    }
  },
  "search": {
    "url": "/common/ajax/physic.asp",
    "method": "GET",
    "params": {
      "f": "1",
      "unityGu": "",
      "physicNm": "{KEYWORD}",
      "venNm": "",
      "insuCd": "",
      "page": "1",
      "often": "0",
      "flag": "",
      "physicCd": "",
      "gu": "",
      "rank": "",
      "mask": "",
      "consCd": "",
      "consCdSeq": "",
      "effect": "0",
      "mode": "list"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "total_count": "totalRec",
      "total_pages": "totalPage",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "pack_unit": "std",
        "manufacturer": "makerNm",
        "stock_quantity": "stock",
        "unit_price": "unitCost",
        "remark": "soldoutMsg"
      }
    },
    "pagination": {
      "type": "param",
      "page_param": "page",
      "start_page": 1,
      "items_per_page": 10,
      "max_pages": 5
    }
  },
  "cart_add": {
    "url": "/common/ajax/bag.asp",
    "method": "POST",
    "content_type": "application/x-www-form-urlencoded",
    "payload": {
      "physicCds": "{PRODUCT_CODE}",
      "qtys": "{QUANTITY}",
      "unitCosts": "{UNIT_PRICE}",
      "mode": "add",
      "ug": "",
      "orderFlag": "1"
    },
    "price_lookup": {
      "url": "/common/ajax/physic.asp",
      "method": "GET",
      "params": {
        "mode": "view",
        "physicCd": "{PRODUCT_CODE}",
        "unityGu": ""
      },
      "price_path": "view.0.unitCost"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "cart_view": {
    "url": "/common/ajax/bag.asp",
    "method": "GET",
    "params": {
      "mode": "list",
      "ug": "",
      "orderFlag": "1"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "pack_unit": "std",
        "manufacturer": "maker",
        "unit_price": "price",
        "quantity": "qty"
      }
    }
  },
  "cart_delete": {
    "url": "/common/ajax/bag.asp",
    "method": "GET",
    "params": {
      "mode": "del",
      "code": "{PRODUCT_CODE}",
      "ug": "",
      "orderFlag": "1"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "cart_clear": {
    "url": "/common/ajax/bag.asp",
    "method": "GET",
    "params": {
      "mode": "delall",
      "ug": "",
      "orderFlag": "1"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "sales_ledger": {
    "url": "/contents/order/saleledger.asp",
    "method": "GET",
    "params": {
      "ug": "",
      "srchFlag": "1",
      "sel_kind": "{DETAIL_MODE}",
      "sel_srch_opt": "",
      "tx_dateA": "{START_DATE}",
      "tx_dateZ": "{END_DATE}",
      "tx_physic_nm": "{PRODUCT_FILTER}"
    },
    "detail_values": {
      "detail": "0",
      "summary": "1"
    },
    "response_type": "html",
    "parsing": {
      "selector": "table.vertical-line tbody tr",
      "fields": {
        "transaction_date": "td:nth-of-type(2)::text",
        "product_name": "td.nm::text",
        "pack_unit": "td:nth-of-type(4)::text",
        "quantity": "td:nth-of-type(5)::text",
        "unit_price": "td:nth-of-type(6)::text",
        "sales_amount": "td:nth-of-type(7)::text"
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true,
    "order_confirm": false
  }
}