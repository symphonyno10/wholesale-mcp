{
  "site_id": "esehwa_co_kr_auto",
  "site_name": "세화약품_auto_retry",
  "site_url": "https://www.esehwa.co.kr",
  "encoding": "utf-8",
  "recipe_version": 1,
  "site_type": "angularjs_cookie",
  "connection": {
    "request_interval_ms": 500
  },
  "login": {
    "method": "POST",
    "url": "/common/ajax/user.asp",
    "payload": {
      "mode": "login",
      "id": "{USERNAME}",
      "pw": "{PASSWORD}",
      "chked": "false"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "search": {
    "method": "GET",
    "url": "/common/ajax/physic.asp",
    "params": {
      "mode": "list",
      "physicNm": "{KEYWORD}",
      "page": "1",
      "f": "1",
      "often": "0",
      "flag": "",
      "venNm": "",
      "insuCd": "",
      "unityGu": ""
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "unit_price": "unitCost",
        "manufacturer": "makerNm",
        "pack_unit": "std",
        "stock_quantity": "stock",
        "remark": "soldoutYN"
      }
    },
    "pagination": {
      "type": "param",
      "page_param": "page",
      "start_page": 1,
      "total_pages_path": "totalPage",
      "max_pages": 10
    }
  },
  "cart_add": {
    "method": "POST",
    "url": "/common/ajax/bag.asp",
    "payload": {
      "mode": "add",
      "physicCds": "{PRODUCT_CODE}",
      "qtys": "{QUANTITY}",
      "unitCosts": "0",
      "ug": "",
      "orderFlag": "1"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "cart_view": {
    "method": "GET",
    "url": "/common/ajax/bag.asp",
    "params": {
      "mode": "list",
      "ug": "",
      "orderFlag": "1"
    },
    "response_type": "json",
    "json_mapping": {
      "items_path": "list",
      "fields": {
        "product_code": "physicCd",
        "product_name": "physicNm",
        "quantity": "qty",
        "unit_price": "price"
      }
    }
  },
  "cart_delete": {
    "method": "GET",
    "url": "/common/ajax/bag.asp",
    "params": {
      "mode": "del",
      "code": "{PRODUCT_CODE}",
      "ug": "",
      "orderFlag": "1"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "cart_clear": {
    "method": "GET",
    "url": "/common/ajax/bag.asp",
    "params": {
      "mode": "delall",
      "ug": "",
      "orderFlag": "1"
    },
    "success_indicator": {
      "type": "json_field",
      "path": "retCode",
      "value": "0000"
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "/contents/order/saleledger.asp",
    "params": {
      "ug": "",
      "srchFlag": "1",
      "sel_kind": "1",
      "sel_srch_opt": "",
      "tx_dateA": "{START_DATE}",
      "tx_dateZ": "{END_DATE}",
      "tx_physic_nm": "{PRODUCT_FILTER}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "#inner-content table tr",
      "fields": {
        "transaction_date": "td:nth-child(2)",
        "product_name": "td:nth-child(3)",
        "pack_unit": "td:nth-child(4)",
        "quantity": "td:nth-child(5)",
        "unit_price": "td:nth-child(6)",
        "sales_amount": "td:nth-child(8)",
        "balance": "td:nth-child(12)"
      }
    }
  },
  "available_features": {
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true,
    "order_submit": false
  }
}