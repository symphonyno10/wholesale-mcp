{
  "manifest_version": "0.3",
  "name": "wholesale-mcp",
  "version": "1.4.0",
  "description": "도매 약품 사이트 자동 주문 — 검색, 장바구니, 매출원장",
  "author": {
    "name": "symphonyno10",
    "url": "https://github.com/symphonyno10/wholesale-mcp"
  },
  "server": {
    "type": "binary",
    "entry_point": "server/wholesale-mcp.exe",
    "mcp_config": {
      "command": "${__dirname}/server/wholesale-mcp.exe",
      "args": [],
      "env": {
        "WHOLESALE_MCP_DATA_DIR": "${user_config.data_dir}",
        "PLAYWRIGHT_BROWSERS_PATH": "${__dirname}/server/playwright-browsers"
      }
    }
  },
  "user_config": {
    "data_dir": {
      "type": "directory",
      "title": "데이터 저장 위치",
      "description": "아이디/비밀번호, 레시피, 매출원장 데이터가 저장됩니다",
      "default": []
    }
  },
  "compatibility": {
    "platforms": ["win32"]
  }
}
