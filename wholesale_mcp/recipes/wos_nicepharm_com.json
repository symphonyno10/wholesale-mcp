{
  "site_id": "wos_nicepharm_com",
  "site_name": "복산나이스",
  "site_url": "https://wos.nicepharm.com",
  "encoding": "utf-8",
  "recipe_version": 4,
  "connection": {
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "method": "POST",
    "url": "https://wos.nicepharm.com/Common/Certify/Login.asp",
    "payload": {
      "tx_id": "{username}",
      "tx_pw": "{password}"
    },
    "success_indicator": {
      "type": "cookie",
      "key": "wos"
    }
  },
  "search": {
    "method": "POST",
    "url": "https://wos.nicepharm.com/Service/Order/Order.asp",
    "params": {
      "UserDef001": "02",
      "so": "0",
      "so2": "0",
      "tx_ven": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "currMkind": "U",
      "sv": "{VEN_CD}",
      "currStockCd": "10001",
      "tx_physic": "{keyword}",
      "tx_maker": ""
    },
    "response_type": "html",
    "parsing": {
      "selector": "#frmOrder .wrap_table table tbody tr",
      "fields": {
        "product_code": {
          "selector": "input[name^=pc_]",
          "attribute": "value"
        },
        "product_name": "td:nth-child(3)",
        "manufacturer": "td:nth-child(2)",
        "pack_unit": "td:nth-child(4)",
        "price": {
          "selector": "input[name^=price_]",
          "attribute": "value"
        },
        "stock_quantity": "td:nth-child(8)",
        "remark": {
          "selector": "input[name^=soldoutyn_]",
          "attribute": "value"
        }
      }
    }
  },
  "cart_add": {
    "type": "form",
    "url": "https://wos.nicepharm.com/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_"
  },
  "cart_view": {
    "method": "GET",
    "url": "https://wos.nicepharm.com/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}",
      "currMkind": "U",
      "currStockCd": "10001"
    },
    "response_type": "html",
    "parsing": {
      "selector": "#bag_view table tbody tr",
      "fields": {
        "product_name": "td:nth-child(2)",
        "quantity": "td:nth-child(3)",
        "total_price": "td:nth-child(4)"
      }
    }
  },
  "cart_clear": {
    "method": "GET",
    "url": "https://wos.nicepharm.com/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}",
      "currMkind": "U"
    },
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "sales_ledger": {
    "method": "GET",
    "url": "https://wos.nicepharm.com/Service/SalesLedger/SalesLedger.asp",
    "date_format": "%Y-%m-%d",
    "params": {
      "sDate": "{start_date}",
      "eDate": "{end_date}",
      "tx_ven": "{VEN_CD}",
      "sv": "{VEN_CD}",
      "currVenNm": "{VEN_NM}",
      "transgu": "0"
    },
    "response_type": "html"
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": false,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": false
  }
}