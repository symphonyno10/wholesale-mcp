{
  "recipe_version": 4,
  "site_url": "https://example-wholesale.com",
  "site_id": "example_form_site",
  "site_name": "예시 도매 (form 방식)",
  "encoding": "utf-8",
  "connection": {
    "pre_login_get": true,
    "request_interval_ms": 500,
    "ssl_verify": true
  },
  "login": {
    "method": "POST",
    "url": "https://example-wholesale.com/Common/Certify/Login.asp",
    "payload": {
      "tx_id": "{USERNAME}",
      "tx_pw": "{PASSWORD}"
    },
    "content_type": "application/x-www-form-urlencoded",
    "success_indicator": {
      "type": "cookie",
      "key": "session_cookie_name"
    }
  },
  "search": {
    "method": "POST",
    "url": "https://example-wholesale.com/Service/Order/Order.asp",
    "params": {
      "tx_physic": "{KEYWORD}",
      "so": "0"
    },
    "response_type": "html",
    "content_type": "application/x-www-form-urlencoded",
    "pagination": {
      "type": "html_links",
      "paging_selector": "div.paging a",
      "page_url_param": "Page",
      "method_override": "GET",
      "max_pages": 5
    },
    "parsing": {
      "selector": "tr.product-row",
      "fields": {
        "product_name": {"selector": "td:nth-child(3) a", "attribute": "text"},
        "product_code": {"selector": "input[name^=pc_]", "attribute": "value"},
        "unit_price": {"selector": "td:nth-child(6)", "attribute": "text"},
        "stock_quantity": {"selector": "input[name^=stock_]", "attribute": "value"},
        "manufacturer": {"selector": "td:nth-child(2)", "attribute": "text"}
      }
    }
  },
  "cart_add": {
    "type": "form",
    "method": "POST",
    "url": "https://example-wholesale.com/Service/Order/BagOrder.asp",
    "form_name": "frmOrder",
    "product_code_prefix": "pc_",
    "quantity_prefix": "qty_",
    "success_indicator": {
      "type": "status_code",
      "value": 200
    }
  },
  "cart_view": {
    "method": "GET",
    "url": "https://example-wholesale.com/Service/Order/Bag.asp",
    "params": {
      "currVenCd": "{VEN_CD}"
    },
    "response_type": "html",
    "parsing": {
      "selector": "tr[id^=bagLine]",
      "fields": {
        "product_name": {"selector": "td.td_nm a", "attribute": "text"},
        "product_code": {"selector": "input[name^=pc_]", "attribute": "value"},
        "quantity": {"selector": "input[name^=bagQty_]", "attribute": "value"},
        "unit_price": {"selector": "input[name^=price_]", "attribute": "value"}
      }
    }
  },
  "cart_delete": {
    "method": "GET",
    "url": "https://example-wholesale.com/Service/Order/BagOrder.asp",
    "params": {
      "kind": "multiupdbag",
      "actflag": "DEL",
      "currVenCd": "{VEN_CD}",
      "orderNum": "{ORDER_NUM}"
    },
    "requires_cart_view": true,
    "order_num_format": "{BAG_NUM}|{PRODUCT_CODE}|{STOCK_CD}|{QUANTITY}",
    "success_indicator": {"type": "status_code", "value": 200}
  },
  "cart_clear": {
    "method": "GET",
    "url": "https://example-wholesale.com/Service/Order/BagOrder.asp",
    "params": {
      "kind": "del",
      "currVenCd": "{VEN_CD}"
    },
    "success_indicator": {"type": "status_code", "value": 200}
  },
  "sales_ledger": {
    "method": "GET",
    "url": "https://example-wholesale.com/Service/SalesLedger/SalesLedger.asp",
    "params": {
      "sDate": "{START_DATE}",
      "eDate": "{END_DATE}",
      "transgu": "{DETAIL_MODE}"
    },
    "detail_values": {"detail": "0", "summary": "1"},
    "response_type": "html",
    "parsing": {
      "selector": "tbody tr",
      "fields": {
        "transaction_date": {"selector": "td:nth-child(2)", "attribute": "text"},
        "product_name": {"selector": "td:nth-child(3)", "attribute": "text"},
        "quantity": {"selector": "td:nth-child(6)", "attribute": "text"},
        "unit_price": {"selector": "td:nth-child(7)", "attribute": "text"},
        "sales_amount": {"selector": "td:nth-child(8)", "attribute": "text"},
        "balance": {"selector": "td:last-child", "attribute": "text"}
      }
    }
  },
  "available_features": {
    "login": true,
    "search": true,
    "cart_add": true,
    "cart_view": true,
    "cart_delete": true,
    "cart_clear": true,
    "sales_ledger": true,
    "pagination": true
  }
}
